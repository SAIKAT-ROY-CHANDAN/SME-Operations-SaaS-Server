{
  "name": "sme-operations-backend",
  "version": "1.0.0",
  "description": "SME Operations Backend API with Prisma, PostgreSQL, Redis, and BullMQ",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "prisma:generate": "npx prisma generate",
    "prisma:seed": "node --loader ts-node/esm prisma/seed.ts"
  },
  "keywords": [
    "express",
    "prisma",
    "postgresql",
    "redis",
    "bullmq",
    "jwt",
    "rbac"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^7.4.2",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.11",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.10.6",
    "prisma": "^7.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
